# Get your Privy App ID from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id

# Polymarket Builder Program credentials
# Get these from https://polymarket.com/settings?tab=builder
POLY_BUILDER_API_KEY=your_builder_api_key
POLY_BUILDER_SECRET=your_builder_secret
POLY_BUILDER_PASSPHRASE=your_builder_passphrase

# Polygon RPC URL (get a free one from Alchemy, Infura, or use public)
# NEXT_PUBLIC_ prefix so it's available client-side for on-chain reads
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-rpc.com

# Bot configuration (optional)
# BOT_CONFIG_PATH=bot/config/default.json  # REST polling (default)
# BOT_CONFIG_PATH=bot/config/websocket.json  # WebSocket mode
